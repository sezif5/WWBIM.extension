<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Навигатор коллизий XML"
        Height="900"
        Width="1700"
        WindowStartupLocation="CenterScreen"
        MinHeight="500"
        MinWidth="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="Фильтр:" />

            <TextBox x:Name="FilterTextBox"
                     Grid.Column="1"
                     Height="28"
                     VerticalContentAlignment="Center"
                     ToolTip="Поиск по модели, проверке, ID, путям и категориям" />

            <Button x:Name="ResetFilterButton"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Width="90"
                    Height="28"
                    Content="Сброс" />

            <Button x:Name="SaveChangesButton"
                    Grid.Column="3"
                    Margin="8,0,0,0"
                    Width="170"
                    Height="28"
                    Content="Сохранить изменения" />

            <Button x:Name="SelectElementButton"
                    Grid.Column="4"
                    Margin="8,0,0,0"
                    Width="110"
                    Height="28"
                    Content="Выделить" />

            <Button x:Name="CropToElementButton"
                    Grid.Column="5"
                    Margin="8,0,0,0"
                    Width="110"
                    Height="28"
                    Content="Подрезать" />

            <TextBlock Grid.Column="6"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Text="Окно немодальное: можно работать в Revit и отрабатывать коллизии" />
        </Grid>

        <DataGrid x:Name="ClashesGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow" />
    </Grid>
</Window>
